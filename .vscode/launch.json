{
  "version": "0.2.0",
  "inputs": [
    {
      "id": "testName",
      "description": "Exact test name to debug (e.g. tests::my_test)",
      "type": "promptString",
      "default": ""
    }
  ],
  "configurations": [
    // ── Runtime ───────────────────────────────────────────
    {
      "type": "lldb",
      "request": "launch",
      "name": "Debug: Agent",
      "program": "${workspaceFolder}/target/debug/zeroclaw",
      "args": ["agent"],
      "cwd": "${workspaceFolder}",
      "preLaunchTask": "Build: Debug"
    },
    {
      "type": "lldb",
      "request": "launch",
      "name": "Debug: Gateway",
      "program": "${workspaceFolder}/target/debug/zeroclaw",
      "args": ["gateway"],
      "cwd": "${workspaceFolder}",
      "env": { "ZEROCLAW_REQUIRE_PAIRING": "false" },
      "preLaunchTask": "Build: Debug"
    },
    {
      "type": "lldb",
      "request": "launch",
      "name": "Debug: Daemon",
      "program": "${workspaceFolder}/target/debug/zeroclaw",
      "args": ["daemon"],
      "cwd": "${workspaceFolder}",
      "preLaunchTask": "Build: Debug"
    },
    {
      "type": "lldb",
      "request": "launch",
      "name": "Debug: Status",
      "program": "${workspaceFolder}/target/debug/zeroclaw",
      "args": ["status"],
      "cwd": "${workspaceFolder}",
      "preLaunchTask": "Build: Debug"
    },
    {
      "type": "lldb",
      "request": "launch",
      "name": "Debug: Quickstart",
      "program": "${workspaceFolder}/target/debug/zeroclaw",
      "args": ["quickstart"],
      "cwd": "${workspaceFolder}",
      "preLaunchTask": "Build: Debug"
    },
    // ── Dev (browser) ────────────────────────────────────
    {
      "type": "chrome",
      "request": "launch",
      "name": "Dev: Browser",
      "url": "http://localhost:5173",
      "webRoot": "${workspaceFolder}/web/src"
    },
    // ── Test ──────────────────────────────────────────────
    {
      "type": "lldb",
      "request": "launch",
      "name": "Debug: Test (by name)",
      "cargo": {
        "args": ["test", "--no-run", "--lib", "--"],
        "filter": {
          "kind": "lib"
        }
      },
      "args": ["--exact", "${input:testName}", "--nocapture"],
      "cwd": "${workspaceFolder}"
    }
  ],
  "compounds": [
    {
      "name": "Dev: Full Stack",
      "configurations": ["Dev: Browser"],
      "preLaunchTask": "Dev: Full Stack (tasks)",
      "stopAll": true,
      "presentation": {
        "order": 1,
        "group": "dev"
      }
    }
  ]
}
